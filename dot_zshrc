# etcd-console aliases (credentials in ~/.etcdrc)
alias etcd-stage='etcd-switch stage'
alias etcd-prod='etcd-switch prod'

# functions
c() {
  [[ -z "$1" ]] && echo "Usage: c <file>" && return 1
  [[ ! -f "$1" ]] && echo "File not found: $1" && return 1
  pbcopy < "$1"
  echo "Copied: $1"
}

# path
path=(
  /usr/local/bin
  /opt/homebrew/bin
  /opt/homebrew/sbin
  $GOBIN
  $HOME/.local/bin
  ${KREW_ROOT:-$HOME/.krew}/bin
  $path
)
typeset -U path

