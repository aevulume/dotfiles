# common env
ZSH_CONFIG_DIR="$HOME/.config/zsh"

# no sessions
unset zsh_session_options

# autocomplete
[[ -d "$HOME/.cache/zsh" ]] || mkdir -p "$HOME/.cache/zsh"
export ZSH_COMPDUMP="$HOME/.cache/zsh/compdump"

# history setup
HISTFILE="$HOME/.cache/zsh/history"
HISTSIZE=999
SAVEHIST=1000
setopt share_history
setopt hist_verify
setopt hist_ignore_dups
setopt hist_expire_dups_first
bindkey '^[[A' history-search-backward
bindkey '^[[B' history-search-forward

# lang env
export LANG=en_US.UTF-8

# vim env
export VIMINFO="$HOME/.cache/vim/info"
if [[ -n $SSH_CONNECTION ]]; then
  export EDITOR="vim"
else
  export EDITOR="vim"
fi

# golang env
export GOPATH="$HOME/.go"
export GOBIN="$GOPATH/bin"
go env -w GOSUMDB="off"
go env -w GOPRIVATE="gitlab.fbs-d.com"
go env -w GOPROXY="https://proxy.golang.org,direct"

# setup oh-my-zsh
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="lambda-minimal"

plugins=(
  chezmoi
  encode64
  eza
  fancy-ctrl-z
  fzf
  git
  golang
  history
  ssh
  zsh-autosuggestions
  zsh-syntax-highlighting
)

# eza
zstyle ':omz:plugins:eza' 'dirs-first' yes
zstyle ':omz:plugins:eza' 'git-status' yes
zstyle ':omz:plugins:eza' 'header' yes
zstyle ':omz:plugins:eza' 'icons' yes

alias gomv='go mod vendor' # for plugin `golang`

# start oh-my-zsh
source $ZSH/oh-my-zsh.sh

# aliases
alias vi='vim'
alias go='richgo'
alias cat='bat --style=plain'
alias lst='eza -laTL=2'
alias less='less -X'
alias wget='wget --no-hsts'
alias zcfg='vi ~/.zshrc && source ~/.zshrc'

alias gp='python3 -c "
  import random;
  import string;
  d=random.choices(string.digits,k=3);
  l=random.choices(string.ascii_lowercase,k=4);
  u=random.choices(string.ascii_uppercase,k=4);
  s=random.choices(\"!@#$%^&*()_+-=[]{}|;:,.<>?\",k=3);
  chars=d+l+u+s;random.shuffle(chars);
  print(\"\".join(chars),end=\"\")" | pbcopy'

